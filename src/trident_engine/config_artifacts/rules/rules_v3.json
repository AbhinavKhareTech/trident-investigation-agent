{
  "version": "3.0",
  "rules": {
    "confirmation_gate": {
      "required_for": ["place_food_order", "checkout_instamart", "book_table"],
      "confirm_words": ["yes", "haan", "ha", "sari", "ok", "confirm", "proceed", "aunu", "amaam"],
      "cancel_words": ["no", "nahi", "cancel", "ruko", "stop", "beda", "venda"],
      "timeout_seconds": 30,
      "readback_required": true,
      "amount_must_be_exact": true
    },
    "fallback": {
      "max_alternatives": 3,
      "min_affinity_score": 0.65,
      "same_cuisine_preferred": true,
      "explain_why_alternative": true
    },
    "cost_controls": {
      "session_hard_cap_tokens": 24600,
      "alert_on_cost_variance_pct": 15,
      "reject_if_utility_ratio_below": 0.5,
      "max_retries_per_tool_call": 3
    },
    "safety": {
      "never_auto_execute_above_amount": 5000,
      "require_hitl_for_refunds": true,
      "allergen_check_mandatory": true,
      "dietary_restrictions_in_every_food_query": true
    },
    "compliance": {
      "provenance_completeness_required": true,
      "audit_retention_years": 7,
      "lineage_graph_mandatory_for_bfsi": true,
      "inference_log_append_only": true
    }
  }
}
